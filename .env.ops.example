# ─────────────────────────────────────────────────────────────────────────────
# OPS-ONLY environment for the directory seeder (scripts/seed-videos.ts).
#
# ⛔ These vars are for running the vetting pipeline BY HAND from a developer
# machine. They must NEVER be added to the Vercel app project, and NEVER be
# prefixed NEXT_PUBLIC. The deployed abya.tv app has no service-role key and no
# write path — that is the whole point. Keep this file's values out of app env.
#
# Copy to .env.local ONLY on the machine that runs `pnpm seed`.
# ─────────────────────────────────────────────────────────────────────────────

# ABYA_TV project (same URL the app reads).
NEXT_PUBLIC_SUPABASE_URL="https://pkzexxqshawljljdyobf.supabase.co"

# Service-role key — writes vetted VIDEO/CHANNEL content only. Zero PII touched.
# Never exposed to the browser, never in the app bundle, never in Vercel app env.
SUPABASE_SERVICE_ROLE_KEY=""

# YouTube Data API v3 key — used to fetch channel/video metadata for scoring.
YOUTUBE_API_KEY=""

# Anthropic API key — Claude Haiku scores each video on the 10-dimension rubric
# and writes the parent_abstract.
ANTHROPIC_API_KEY=""
