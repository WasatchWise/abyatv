# ─────────────────────────────────────────────────────────────────────────────
# abya.tv environment — ZERO PII. Read-only. Anon key ONLY.
#
# There is NO service-role key here on purpose. The app has no table to write
# PII into and no key that could do it. Do not add SUPABASE_SERVICE_ROLE_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# ABYA_TV Supabase project (pkzexxqshawljljdyobf) — public read, RLS enforced.
NEXT_PUBLIC_SUPABASE_URL="https://pkzexxqshawljljdyobf.supabase.co"

# ABYA_TV anon (publishable) key. Safe to expose to the browser; RLS restricts it
# to public-read of the three vetted-content tables. Get it from:
#   supabase projects api-keys --project-ref pkzexxqshawljljdyobf   (the "anon" row)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# The Agency apex — where every gated-episode click and the membership pitch go.
# ALWAYS the apex, never a *.askbeforeyouapp.com district subdomain.
NEXT_PUBLIC_AGENCY_URL="https://askbeforeyouapp.com"

# Hub intro video (R2). Poster/hero on the homepage.
NEXT_PUBLIC_HUB_VIDEO_URL="https://media.askbeforeyouapp.com/hub-intro-five-pillars-v4.mp4"
